<section class="claude-mod-campaign-assistant {{#unless sidebarOpen}}sidebar-collapsed{{/unless}}">
  <header class="claude-mod-assistant-header">
    <div class="claude-mod-assistant-title">
      <i class="fa-solid fa-sparkles"></i>
      <h2>{{localize "CLAUDE-MOD.CampaignAssistant.Title"}}</h2>
      {{#if suggestionCount}}
      <span class="claude-mod-suggestion-badge">{{suggestionCount}} {{localize "CLAUDE-MOD.CampaignAssistant.Suggestions"}}</span>
      {{/if}}
    </div>
    <div class="claude-mod-assistant-header-actions">
      <button type="button" class="claude-mod-icon-button" data-action="newConversation" title="{{localize "CLAUDE-MOD.NewConversation"}}" {{#if loading}}disabled{{/if}}>
        <i class="fa-solid fa-rotate-left"></i>
      </button>
      <button type="button" class="claude-mod-icon-button" data-action="toggleSidebar" title="{{localize "CLAUDE-MOD.CampaignAssistant.ToggleSidebar"}}">
        <i class="fa-solid {{#if sidebarOpen}}fa-chevron-right{{else}}fa-chevron-left{{/if}}"></i>
      </button>
    </div>
  </header>

  <main class="claude-mod-assistant-main">
    <section class="claude-mod-chat-panel">
      <header class="claude-mod-panel-header">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
        <span>{{localize "CLAUDE-MOD.CampaignAssistant.ChatTitle"}}</span>
      </header>

      <div class="claude-mod-chat-transcript" data-chat-transcript>
        {{#if messages.length}}
          {{#each messages}}
          <article class="claude-mod-transcript-message claude-mod-transcript-message--{{role}}">
            <div class="claude-mod-transcript-bubble">{{{contentHtml}}}</div>
          </article>
          {{/each}}
        {{else}}
          <p class="claude-mod-chat-empty">{{localize "CLAUDE-MOD.CampaignAssistant.ChatEmpty"}}</p>
        {{/if}}

        {{#if loading}}
        <article class="claude-mod-transcript-message claude-mod-transcript-message--assistant">
          <div class="claude-mod-transcript-bubble claude-mod-typing-indicator">
            <span></span><span></span><span></span>
          </div>
        </article>
        {{/if}}
      </div>

      {{#unless hasApiKey}}
      <p class="claude-mod-warning">
        <i class="fa-solid fa-triangle-exclamation"></i>
        {{localize "CLAUDE-MOD.NoApiKeyWarning"}}
      </p>
      {{/unless}}

      <form class="claude-mod-chat-input" data-action="sendMessage">
        <textarea
          name="message"
          rows="1"
          placeholder="{{localize "CLAUDE-MOD.CampaignAssistant.MessagePlaceholder"}}"
          {{#unless hasApiKey}}disabled{{/unless}}
          {{#if loading}}disabled{{/if}}
        ></textarea>
        <button type="submit" data-action="sendMessage" {{#unless hasApiKey}}disabled{{/unless}} {{#if loading}}disabled{{/if}}>
          <i class="fa-solid fa-paper-plane"></i>
        </button>
      </form>
    </section>

    <section class="claude-mod-world-summary">
      <header class="claude-mod-panel-header">
        <div class="claude-mod-panel-header-title">
          <i class="fa-solid fa-globe"></i>
          <span>{{localize "CLAUDE-MOD.CampaignAssistant.WorldTitle"}}</span>
        </div>
        <button type="button" class="claude-mod-icon-button" data-action="refreshWorldSummary" title="{{localize "CLAUDE-MOD.CampaignAssistant.RefreshWorld"}}">
          <i class="fa-solid fa-rotate"></i>
        </button>
      </header>

      <div class="claude-mod-world-summary-body">
        {{#if worldSummary.text}}
          <p class="claude-mod-world-summary-text">{{worldSummary.text}}</p>
          {{#if worldSummary.truncated}}
          <p class="claude-mod-world-summary-note">{{localize "CLAUDE-MOD.CampaignAssistant.WorldTruncated"}}</p>
          {{/if}}
        {{else}}
          <p class="claude-mod-world-summary-empty">{{localize "CLAUDE-MOD.CampaignAssistant.WorldEmpty"}}</p>
        {{/if}}
      </div>

      <footer class="claude-mod-world-summary-footer">
        <i class="fa-solid fa-lightbulb"></i>
        <span>{{localize "CLAUDE-MOD.CampaignAssistant.WorldFollowUp"}}</span>
      </footer>
    </section>
  </main>

  <aside class="claude-mod-assistant-sidebar">
    <section class="claude-mod-sidebar-section claude-mod-suggested-docs">
      <header class="claude-mod-sidebar-header">
        <span>{{localize "CLAUDE-MOD.CampaignAssistant.SuggestedDocuments"}} ({{suggestionCount}})</span>
      </header>

      {{#if suggestions.length}}
      <div class="claude-mod-suggestion-actions">
        <button type="button" class="claude-mod-suggestion-action claude-mod-suggestion-action--accept" data-action="acceptAllSuggestions">
          <i class="fa-solid fa-check"></i> {{localize "CLAUDE-MOD.CampaignAssistant.AcceptAll"}}
        </button>
        <button type="button" class="claude-mod-suggestion-action" data-action="dismissAllSuggestions">
          {{localize "CLAUDE-MOD.CampaignAssistant.DismissAll"}}
        </button>
      </div>

      <ul class="claude-mod-suggestion-list">
        {{#each suggestions}}
        <li class="claude-mod-suggestion-card" data-suggestion-id="{{id}}">
          <div class="claude-mod-suggestion-card-main">
            <i class="fa-solid {{icon}}"></i>
            <div class="claude-mod-suggestion-card-body">
              <span class="claude-mod-suggestion-title">{{title}}</span>
              {{#if tagLabels}}
              <span class="claude-mod-suggestion-tags">{{tagLabels}}</span>
              {{/if}}
              {{#if snippet}}
              <p class="claude-mod-suggestion-snippet">{{snippet}}</p>
              {{/if}}
            </div>
          </div>
          <div class="claude-mod-suggestion-card-actions">
            <button type="button" class="claude-mod-icon-button claude-mod-suggestion-accept" data-action="acceptSuggestion" data-suggestion-id="{{id}}" title="{{localize "CLAUDE-MOD.CampaignAssistant.AcceptSuggestion"}}">
              <i class="fa-solid fa-check"></i>
            </button>
            <button type="button" class="claude-mod-icon-button" data-action="dismissSuggestion" data-suggestion-id="{{id}}" title="{{localize "CLAUDE-MOD.CampaignAssistant.DismissSuggestion"}}">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="claude-mod-sidebar-placeholder">{{localize "CLAUDE-MOD.CampaignAssistant.SuggestionsEmpty"}}</p>
      {{/if}}
    </section>

    <section class="claude-mod-sidebar-section claude-mod-recently-created">
      <header class="claude-mod-sidebar-header">
        <span>{{localize "CLAUDE-MOD.CampaignAssistant.RecentlyCreated"}} ({{recentlyCreated.length}})</span>
      </header>

      {{#if recentlyCreated.length}}
      <ul class="claude-mod-recent-list">
        {{#each recentlyCreated}}
        <li>
          <button
            type="button"
            class="claude-mod-recent-item"
            data-action="openRecent"
            data-document-type="{{documentType}}"
            data-document-id="{{documentId}}"
            {{#if parentId}}data-parent-id="{{parentId}}"{{/if}}
          >
            <i class="fa-solid {{icon}}"></i>
            <span class="claude-mod-recent-title">{{title}}</span>
            <span class="claude-mod-recent-date">{{dateLabel}}</span>
          </button>
        </li>
        {{/each}}
      </ul>
      <footer class="claude-mod-sidebar-footer">
        <button type="button" class="claude-mod-sidebar-link" data-action="openKnowledgeBase">
          <i class="fa-solid fa-book"></i> {{localize "CLAUDE-MOD.CampaignAssistant.KnowledgeBase"}}
        </button>
        <button type="button" class="claude-mod-sidebar-link" data-action="openPlayMaterials">
          <i class="fa-solid fa-shield"></i> {{localize "CLAUDE-MOD.CampaignAssistant.PlayMaterials"}}
        </button>
      </footer>
      {{else}}
      <p class="claude-mod-sidebar-placeholder">{{localize "CLAUDE-MOD.CampaignAssistant.RecentEmpty"}}</p>
      <footer class="claude-mod-sidebar-footer">
        <button type="button" class="claude-mod-sidebar-link" data-action="openKnowledgeBase">
          <i class="fa-solid fa-book"></i> {{localize "CLAUDE-MOD.CampaignAssistant.KnowledgeBase"}}
        </button>
        <button type="button" class="claude-mod-sidebar-link" data-action="openPlayMaterials">
          <i class="fa-solid fa-shield"></i> {{localize "CLAUDE-MOD.CampaignAssistant.PlayMaterials"}}
        </button>
      </footer>
      {{/if}}
    </section>

    <section class="claude-mod-sidebar-section claude-mod-quick-create">
      <header class="claude-mod-sidebar-header">
        <span>{{localize "CLAUDE-MOD.CampaignAssistant.QuickCreate"}}</span>
      </header>
      <div class="claude-mod-quick-create-grid">
        {{#each quickCreateTypes}}
        <button type="button" class="claude-mod-quick-create-button" data-action="quickCreate" data-create-type="{{id}}">
          <i class="fa-solid {{icon}}"></i>
          <span>{{label}}</span>
        </button>
        {{/each}}
      </div>
    </section>
  </aside>
</section>
